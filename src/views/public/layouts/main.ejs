<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="shortcut icon" href="/assets/images/favicon.webp" type="image/x-icon" />
    <link rel="icon" href="/assets/images/favicon.webp" type="image/x-icon" />
    
    <%
      const seoDefaults = typeof pageSeo !== "undefined" ? pageSeo : {};
    %>
    <%- include('../partials/seo-meta', {
      defaultTitle: seoDefaults.title || 'Pioneer Flex | PVC Processing, Signage, Decorative Films & Industrial Products',
      defaultDescription: seoDefaults.description || 'Pioneer Polyleathers is a leading PVC processing company offering signage products, decorative films, PVC tapes, and industrial laminated products.',
      defaultKeywords: seoDefaults.keywords || ['pvc processing', 'flex banner', 'signage', 'pvc films', 'decorative laminates', 'pvc tapes', 'industrial products'],
      defaultImage: seoDefaults.image || '/assets/images/banner/banner1.webp',
      defaultCanonicalPath: seoDefaults.canonicalPath || '',
      defaultRobots: seoDefaults.robots || 'index, follow'
    }) %>
    <link rel="stylesheet" href="/assets/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/assets/fonts/css/all.min.css" />
    <link rel="stylesheet" href="/assets/fonts/css/tabler-icons.min.css" />
    <link rel="stylesheet" href="/assets/css/magnific-popup.css" />
    <link rel="stylesheet" href="/assets/css/nice-select.css" />
    <link rel="stylesheet" href="/assets/css/odometer.css" />
    <link rel="stylesheet" href="/assets/css/swiper-bundle.min.css" />
    <link rel="stylesheet" href="/assets/css/main.css" />
    <link rel="stylesheet" href="/assets/css/product.css" />
    <link rel="stylesheet" href="/assets/css/louvers.css" />
    <link rel="stylesheet" href="/assets/css/image-lightbox.css?v=1" />
    <link rel="stylesheet" href="/assets/css/page-sections.css" />
  </head>
  <body class="<%= typeof publicBodyClass !== 'undefined' ? publicBodyClass : '' %>">
    <div class="<%= typeof publicWrapperClass !== 'undefined' ? publicWrapperClass : 'page-wrapper' %>"<%- typeof publicWrapperId !== 'undefined' && publicWrapperId ? ` id="${publicWrapperId}"` : '' %>>
      <%- include('../partials/header') %>
      <%- body %>
      <%- include('../partials/footer') %>

      <div class="lines l-alt">
        <div class="line"></div>
        <div class="line"></div>
        <div class="line"></div>
      </div>

      <div class="mouseCursor cursor-outer"></div>
      <div class="mouseCursor cursor-inner">
        <span class="drag"> drag </span>
        <span class="view"> view </span>
        <span class="play"> play </span>
      </div>

      <button class="progress-wrap" aria-label="scroll indicator" title="back to top">
        <span></span>
        <svg class="progress-circle svg-content" width="100%" height="100%" viewBox="-1 -1 102 102">
          <path d="M50,1 a49,49 0 0,1 0,98 a49,49 0 0,1 0,-98" />
        </svg>
      </button>
    </div>
  </body>
</html>
