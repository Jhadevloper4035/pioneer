<section class="pioneer-page-hero" style="--page-hero-image: url('<%= category.image || "/assets/images/banner/banner1.webp" %>');">
  <div class="container-lg">
    <div class="pioneer-page-hero__content fade-up">
      <span class="pioneer-page-hero__tag"><%= category.tag %></span>
      <h1 class="pioneer-page-hero__title elicyon"><%= category.title %></h1>
      <p class="pioneer-page-hero__text"><%= category.text %></p>
      <a class="btn-quinary pioneer-page-hero__button" href="#<%= category.anchor || 'category-heading' %>">
        <span class="btn-animated-text" data-text="View Category">View Category</span>
      </a>
    </div>
  </div>
</section>




<!-- ==== Baffles  section start ==== -->
<section class="louver-composition" aria-labelledby="louver-composition-title">
  <div class="container-lg">
    <div class="louver-composition__grid">
      <div class="louver-composition__content fade-up">
        <p class="louver-composition__eyebrow">(Engineered Material)</p>
        <h2 class="louver-composition__title" id="louver-composition-title">
          PVC Baffles
        </h2>
        <p>
          PVC baffles are lightweight, durable, and
          cost-effective acoustic panels—typically
          made from PVC suspended vertically from
          ceilings or mounted on walls to manage
          sound, reduce reverberation, and enhance
          aesthetics in large, open, or high-noise
          spaces. They are fire-resistant, easy to
          clean, and commonly used in gyms, offices,
          and restaurants

        </p>
      </div>

      <div class="louver-composition__visual fade-up" data-delay="160">
        <a class="louver-composition__image-link" href="/assets/images/category/baffles.jpeg" data-lightbox-image aria-label="View full Pioneer PVC WPC baffles image">
          <img src="/assets/images/category/baffles.jpeg" alt="Pioneer PVC WPC baffles for acoustic and decorative interiors" loading="lazy" />
        </a>
      </div>
    </div>
  </div>
</section>
<!-- ==== / Baffles section end ==== -->





<!-- ==== why choose section start ==== -->
<section class="why-choose pt-140 pb-140 template-bg">
  <div class="container-lg">

    <div class="row">
      <div class="col-12">
        <div class="decorative-services__header fade-up">
          <p class="txt-light">
            (The Modern Alternative to Real Wood Paneling)
          </p>
          <h2 class="decorative-services__title title-animation elicyon fw-3 mt-12" id="pvc-wpc-baffles-benefits-title">
            Key Features and Benefits PVC Baffles
          </h2>
          <p class="decorative-services__intro txt-light">
            Add clean linear detail and acoustic control with durable PVC/WPC baffles.
          </p>
        </div>
      </div>
    </div>


    <div class="why-choose__grid mt-80">
      <article class="why-choose__single fade-up">
        <span>01</span>
        <h3>Acoustic Control</h3>
        <p>
          They absorb sound from all sides,
          effectively reducing echoing and increasing speech clarity
          in, for example, high-ceiling environments.

        </p>
      </article>
      <article class="why-choose__single fade-up" data-delay="150">
        <span>02</span>
        <h3>Versatile Design</h3>
        <p>
          Available in various colors (black, white,
          grey), they offer a clean, modern, linear look that allows for
          easy integration with lighting, sprinklers, and HVAC
          systems.
        </p>
      </article>
      <article class="why-choose__single fade-up" data-delay="300">
        <span>03</span>
        <h3>Durable & Hygienic</h3>
        <p>
          Made with sturdy materials that are
          easy to wipe down, making them suitable for areas
          requiring hygiene.
        </p>
      </article>
      <article class="why-choose__single fade-up" data-delay="450">
        <span>04</span>
        <h3>Easy Installation</h3>
        <p>
          They are typically suspended via hooks
          or grommets from open trusses or existing ceilings.

        </p>
      </article>
    </div>
  </div>
</section>
<!-- ==== / why choose section end ==== -->
