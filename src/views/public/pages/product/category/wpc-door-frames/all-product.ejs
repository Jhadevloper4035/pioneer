<section class="pioneer-page-hero" style="--page-hero-image: url('<%= category.image || "/assets/images/banner/banner1.webp" %>');">
  <div class="container-lg">
    <div class="pioneer-page-hero__content fade-up">
      <span class="pioneer-page-hero__tag"><%= category.tag %></span>
      <h1 class="pioneer-page-hero__title elicyon"><%= category.title %></h1>
      <p class="pioneer-page-hero__text"><%= category.text %></p>
      <a class="btn-quinary pioneer-page-hero__button" href="#<%= category.anchor || 'category-heading' %>">
        <span class="btn-animated-text" data-text="View Category">View Category</span>
      </a>
    </div>
  </div>
</section>

<!-- ==== WPC frames section start ==== -->
<section class="louver-composition" aria-labelledby="wpc-frames-title">
  <div class="container-lg">
    <div class="louver-composition__grid">
      <div class="louver-composition__visual fade-up" data-delay="160">
        <a class="louver-composition__image-link" href="/assets/images/category/wpc-doors-frame.png"
          data-lightbox-image aria-label="View full Pioneer WPC door frame image">
          <img src="/assets/images/category/wpc-doors-frame.png"
            alt="Pioneer WPC door frame for moisture-resistant interior fitment" loading="lazy" />
        </a>
      </div>

      <div class="louver-composition__content fade-up">
        <p class="louver-composition__eyebrow">(Engineered Material)</p>
        <h2 class="louver-composition__title" id="wpc-frames-title">
          WPC Door Frames
        </h2>
        <p>
          WPC (Wood Polymer Composite) door
          frames are durable, eco-friendly structural
          supports made from a mixture of wood
          fiber/flour and thermoplastics. They
          are 100% waterproof, termite-proof, and
          warp-resistant, making them superior to
          traditional wood for high-moisture areas like
          bathrooms, kitchens, main doors, and
          interior doors.
        </p>
      </div>
    </div>
  </div>
</section>
<!-- ==== / WPC frames section end ==== -->

<!-- ==== WPC frame specifications section start ==== -->
<section class="door-specs frame-specs" aria-labelledby="wpc-frame-specs-title">
  <div class="container-lg">
    <div class="door-specs__shell">
      <header class="door-specs__header fade-up">
        <p class="door-specs__eyebrow">Frame Sizing</p>
        <h2 class="door-specs__title elicyon" id="wpc-frame-specs-title">
          WPC Door Frames Specifications
        </h2>
        <p class="door-specs__intro">
          Standard density, length, and cross-section options for WPC door frame applications.
        </p>
      </header>

      <div class="frame-specs__body">
        <figure class="door-specs__visual frame-specs__visual fade-up">
          <a href="/assets/images/category/2.5x4.png" data-lightbox-image aria-label="View full Pioneer WPC door frame image">
            <img src="/assets/images/category/2.5x4.png" alt="Pioneer WPC door frame section sample" loading="lazy" />
          </a>
        </figure>

        <dl class="frame-specs__table fade-up" data-delay="120">
          <div>
            <dt>Density</dt>
            <dd>800 kg/m3 &amp; 1000 kg/m3</dd>
          </div>
          <div>
            <dt>Standard Length</dt>
            <dd>3ft to 10ft</dd>
          </div>
          <div>
            <dt>Cross Section Size Inch</dt>
            <dd>3x2, 4x2, 4x2.5, 5x2.5, 6x2.5</dd>
          </div>
        </dl>
      </div>
    </div>
  </div>
</section>
<!-- ==== / WPC frame specifications section end ==== -->

<!-- ==== why choose-frame section start ==== -->
<section class="why-choose pt-140 pb-140 template-bg">
  <div class="container-lg">
    <div class="row">
      <div class="col-12">
        <div class="decorative-services__header fade-up">
          <p class="txt-light">
            (The Modern Alternative to Real Wood Paneling)
          </p>
          <h2 class="decorative-services__title title-animation elicyon fw-3 mt-12"
            id="wpc-frames-benefits-title">
            Key Features and Benefits of WPC Frames
          </h2>
          <p class="decorative-services__intro txt-light">
            Choose WPC frames for stable, easy-clean support in humid and high-use interiors.
          </p>
        </div>
      </div>
    </div>

    <div class="why-choose__grid mt-80">
      <article class="why-choose__single fade-up">
        <span>01</span>
        <h3>Durability</h3>
        <p>
          Highly resistant to rot, decay, and
          insect damage.
        </p>
      </article>
      <article class="why-choose__single fade-up" data-delay="150">
        <span>02</span>
        <h3>Moisture Resistant</h3>
        <p>
          Unlike wood, they do not
          swell, shrink, or warp when exposed to water or
          humidity.
        </p>
      </article>
      <article class="why-choose__single fade-up" data-delay="300">
        <span>03</span>
        <h3>Maintenance-Free</h3>
        <p>
          They do not require
          painting or polishing and are easy to clean.
        </p>
      </article>
      <article class="why-choose__single fade-up" data-delay="450">
        <span>04</span>
        <h3>Installation</h3>
        <p>
          Lighter than wood, allowing for
          faster and easier installation.
        </p>
      </article>
      <article class="why-choose__single fade-up" data-delay="450">
        <span>05</span>
        <h3>Versatility</h3>
        <p>
          Can be cut, drilled, and screwed
          just like wood.
        </p>
      </article>
    </div>
  </div>
</section>
<!-- ==== / why choose section end ==== -->
