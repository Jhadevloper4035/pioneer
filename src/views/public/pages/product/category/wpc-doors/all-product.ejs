<section class="pioneer-page-hero" style="--page-hero-image: url('<%= category.image || "/assets/images/banner/banner1.webp" %>');">
  <div class="container-lg">
    <div class="pioneer-page-hero__content fade-up">
      <span class="pioneer-page-hero__tag"><%= category.tag %></span>
      <h1 class="pioneer-page-hero__title elicyon"><%= category.title %></h1>
      <p class="pioneer-page-hero__text"><%= category.text %></p>
      <a class="btn-quinary pioneer-page-hero__button" href="#<%= category.anchor || 'category-heading' %>">
        <span class="btn-animated-text" data-text="View Category">View Category</span>
      </a>
    </div>
  </div>
</section>

<!-- ==== WPC doors section start ==== -->
<section class="louver-composition" aria-labelledby="wpc-doors-title">
  <div class="container-lg">
    <div class="louver-composition__grid">
      <div class="louver-composition__content fade-up">
        <p class="louver-composition__eyebrow">(Engineered Material)</p>
        <h2 class="louver-composition__title" id="wpc-doors-title">
          WPC Doors
        </h2>
        <p>
          WPC doors, or Wood Plastic Composite
          doors, are engineered, eco-friendly doors
          made from a mix of wood fiber,
          thermoplastics, and additives. They offer the
          aesthetic of wood with superior, long-lasting
          durability, being 100% waterproof, termiteproof, fire-resistant, and low-maintenance.
          They are ideal for high-moisture areas like
          kitchens and bathrooms.
        </p>
      </div>

      <div class="louver-composition__visual fade-up" data-delay="160">
        <a class="louver-composition__image-link" href="/assets/images/projects/wpc-doors.jpeg"
          data-lightbox-image aria-label="View full Pioneer WPC door image">
          <img src="/assets/images/projects/wpc-doors.jpeg"
            alt="Pioneer WPC door for moisture-resistant interior fitment" loading="lazy" />
        </a>
      </div>
    </div>
  </div>
</section>
<!-- ==== / WPC doors section end ==== -->


<!-- ==== WPC doors specifications section start ==== -->
<section class="door-specs" aria-labelledby="wpc-door-specs-title">
  <div class="container-lg">
    <div class="door-specs__shell">
      <header class="door-specs__header fade-up">
        <p class="door-specs__eyebrow">Product Sizing</p>
        <h2 class="door-specs__title elicyon" id="wpc-door-specs-title">
          WPC Doors Specifications
        </h2>
        <p class="door-specs__intro">
          Standard WPC door dimensions for main doors, bedrooms, bathrooms, and toilet door applications.
        </p>
      </header>

      <div class="door-specs__body">
        <div class="door-specs__details fade-up" data-delay="80">
          <dl class="door-specs__cards">
            <div class="door-specs__card">
              <dt>Height</dt>
              <dd>
                <strong>69&quot; - 90&quot;</strong>
                <span>69&quot;, 72&quot;, 75&quot;, 78&quot;, 81&quot;, 84&quot;, 90&quot;</span>
              </dd>
            </div>
            <div class="door-specs__card">
              <dt>Width</dt>
              <dd>
                <strong>26&quot; - 38&quot;</strong>
                <span>26&quot;, 28&quot;, 30&quot;, 32&quot;, 34&quot;, 36&quot;, 38&quot;</span>
              </dd>
            </div>
            <div class="door-specs__card">
              <dt>Thickness</dt>
              <dd>
                <strong>24 - 35 mm</strong>
                <span>24 mm, 25 mm, 26 mm, 28 mm, 30 mm, 35 mm</span>
              </dd>
            </div>
          </dl>

          <div class="door-specs__sizes">
            <h3>Commonly Used Sizes by Application</h3>
            <ul>
              <li>
                <span>Main Door</span>
                <strong>84&quot; x 36&quot;</strong>
                <em>7ft x 3ft</em>
              </li>
              <li>
                <span>Bedroom Door</span>
                <strong>81&quot; x 33&quot; or 81&quot; x 36&quot;</strong>
                <em>6.75ft x 2.75ft or 6.75ft x 3ft</em>
              </li>
              <li>
                <span>Bathroom / Toilet Door</span>
                <strong>72&quot; x 26&quot;, 72&quot; x 28&quot;, or 72&quot; x 30&quot;</strong>
                <em>6ft x 2.16ft to 6ft x 2.5ft</em>
              </li>
            </ul>
          </div>
        </div>

        <figure class="door-specs__visual fade-up" data-delay="160">
          <a href="/assets/images/category/wpc-solid-doors.jpg" data-lightbox-image aria-label="View full Pioneer WPC door image">
            <img src="/assets/images/category/wpc-solid-doors.jpg" alt="Pioneer WPC door specifications sample" loading="lazy" />
          </a>
        </figure>
      </div>

      <p class="door-specs__note fade-up" data-delay="220">
        WPC doors can be customized to any size according to user requirements.
      </p>
    </div>
  </div>
</section>
<!-- ==== / WPC doors specifications section end ==== -->


<!-- ==== why choose-doors section start ==== -->
<section class="why-choose pt-140 pb-140 template-bg">
  <div class="container-lg">
    <div class="row">
      <div class="col-12">
        <div class="decorative-services__header fade-up">
          <p class="txt-light">
            (The Modern Alternative to Real Wood Paneling)
          </p>
          <h2 class="decorative-services__title title-animation elicyon fw-3 mt-12"
            id="wpc-doors-benefits-title">
            Key Features and Benefits of <br> WPC Doors
          </h2>
          <p class="decorative-services__intro txt-light">
            Build moisture-resistant, termite-resistant interior doors with a low-maintenance WPC finish.
          </p>
        </div>
      </div>
    </div>

    <div class="why-choose__grid mt-80">
      <article class="why-choose__single fade-up">
        <span>01</span>
        <h3>Waterproof & Rot Resistant:</h3>
        <p>
          Unlike traditional
          wood, WPC doors do not swell, warp, or decay,
          making them excellent for bathrooms, toilets,
          and wet areas.
        </p>
      </article>
      <article class="why-choose__single fade-up" data-delay="150">
        <span>02</span>
        <h3>Termite-Proof</h3>
        <p>
          They are highly resistant to
          pests and decay.
        </p>
      </article>
      <article class="why-choose__single fade-up" data-delay="300">
        <span>03</span>
        <h3>Low Maintenance</h3>
        <p>
          WPC doors do not require
          painting, polishing, or frequent repairs.
        </p>
      </article>
      <article class="why-choose__single fade-up" data-delay="450">
        <span>04</span>
        <h3>High Durability</h3>
        <p>
          These doors are sturdy, with
          high screw-holding capacity, and are built for
          high-traffic areas.
        </p>
      </article>
      <article class="why-choose__single fade-up" data-delay="450">
        <span>05</span>
        <h3>Eco-Friendly</h3>
        <p>
          They are often made from
          recycled materials, contributing to sustainability.
        </p>
      </article>
      <article class="why-choose__single fade-up" data-delay="450">
        <span>06</span>
        <h3>Versatile Design</h3>
        <p>
          They come in various
          finishes, colors, and textures that can mimic
          wood.
        </p>
      </article>
    </div>
  </div>
</section>
<!-- ==== / why choose section end ==== -->
