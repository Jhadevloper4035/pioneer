<% const legalHero = typeof hero !== "undefined" && hero ? hero : { tag: "", title: "", text: "" }; %>
<section class="pioneer-page-hero" style="--page-hero-image: url('assets/images/infrastructure/banner.jpg');">
  <div class="container-lg">
    <div class="pioneer-page-hero__content fade-up">
      <span class="pioneer-page-hero__tag"><%= legalHero.tag %></span>
      <h1 class="pioneer-page-hero__title elicyon"><%= legalHero.title %></h1>
      <% if (legalHero.text) { %>
        <p class="pioneer-page-hero__text"><%= legalHero.text %></p>
      <% } %>
      <a class="btn-quinary pioneer-page-hero__button" href="/contact-us">
        <span class="btn-animated-text" data-text="Contact Us">Contact Us</span>
      </a>
    </div>
  </div>
</section>

      <main class="legal-section">
        <div class="container-lg">
          <div class="legal-section__grid">
            <aside class="legal-section__aside">
              <strong>Pioneer Decor</strong>
              <p>
                These pages are provided to clarify website use, enquiry handling,
                and communication practices for Pioneer Decor visitors and customers.
              </p>
            </aside>
            <div class="legal-section__content">
              <% sections.forEach((section) => { %>
                <article class="legal-card">
                  <h2><%= section.title %></h2>
                  <% section.body.forEach((paragraph) => { %>
                    <p><%= paragraph %></p>
                  <% }); %>
                </article>
              <% }); %>
            </div>
          </div>
        </div>
      </main>
