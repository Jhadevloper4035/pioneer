<%
      const openings = Array.isArray(careerOpenings) ? careerOpenings : [];
    %>
    

      <%- include('../../partials/page-hero', {
        tag: '(Career)',
        title: 'Build your future with Pioneer',
        text: 'Join a manufacturing-led team working across PVC Decorative Films, PVC/WPC Interior Louvers, WPC Doors and Frames, and PVC/WPC Baffles.',
        image: 'assets/images/infrastructure/banner.jpeg',
        buttonText: 'Current Openings',
        buttonLink: '#current-openings'
      }) %>

      <section class="career-intro pt-140 pb-100 bg-alt-2">
        <div class="container-lg">
          <div class="row gutter-40 align-items-end">
            <div class="col-12 col-lg-7 fade-up">
              <p class="sub-title mb-4">People at Pioneer</p>
              <h2 class="career-title elicyon">Work with a team focused on quality, scale, and  supply.</h2>
            </div>
            <div class="col-12 col-lg-5 fade-up" data-delay="120">
              <p class="career-copy">
                Pioneer Polyleathers (P) Limited brings together sourcing, processing, coating, laminating,
                finishing, and dispatch under one system. We look for people who care about details,
                customer trust, and practical execution.
              </p>
            </div>
          </div>

          <div class="career-values mt-80">
            <article class="career-value fade-up">
              <span>01</span>
              <h3>Manufacturing Mindset</h3>
              <p>Hands-on production, finishing, packing, and dispatch discipline.</p>
            </article>
            <article class="career-value fade-up" data-delay="120">
              <span>02</span>
              <h3>Product Learning</h3>
              <p>Learn decorative films, louvers, WPC doors, baffles, and interior markets.</p>
            </article>
            <article class="career-value fade-up" data-delay="240">
              <span>03</span>
              <h3>Steady Growth</h3>
              <p>A stable environment for people who like clear responsibilities and long-term work.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="career-openings pt-100 pb-140" id="current-openings">
        <div class="container-lg">
          <div class="career-openings__header fade-up">
            <p class="sub-title">Current Openings</p>
            <h2 class="career-title elicyon">Find the right role at Pioneer.</h2>
            <p class="career-copy">
              <% if (openings.length) { %>
                Explore open positions and submit your profile directly from the role page, or share your profile for future roles.
              <% } else { %>
                No active openings are listed right now. Share your profile and we will keep it for future reference.
              <% } %>
            </p>
          </div>

          <% if (openings.length) { %>
            <div class="career-openings__grid">
              <% openings.forEach((opening, index) => { %>
                <article class="career-card fade-up" data-delay="<%= index * 90 %>">
                  <div class="career-card__meta">
                    <span><%= opening.department %></span>
                    <span><%= opening.type %></span>
                  </div>
                  <h3 class="elicyon"><%= opening.title %></h3>
                  <p><%= opening.summary %></p>
                  <dl>
                    <div>
                      <dt>Location</dt>
                      <dd><%= opening.location %></dd>
                    </div>
                    <div>
                      <dt>Experience</dt>
                      <dd><%= opening.experience %></dd>
                    </div>
                  </dl>
                  <a class="btn-quinary career-card__link" href="/career/<%= opening.slug %>">
                    <span class="btn-animated-text" data-text="View Opening">View Opening</span>
                  </a>
                </article>
              <% }); %>
            </div>
          <% } %>

          <div class="career-openings__empty fade-up">
            <div class="career-openings__empty-intro">
              <h3 class="elicyon">Share your profile for future roles.</h3>
              <p>
                Send your details and resume to the Pioneer team. We will review your profile when a suitable
                opportunity opens across sales, production, quality, dispatch, office, or internship roles.
              </p>
            </div>
            <form
              class="career-application-form"
              action="/api/career-application"
              method="post"
              enctype="multipart/form-data"
              data-career-application-form
            >
              <div class="row g-4">
                <div class="col-md-6 career-application-form__field">
                  <label for="career-general-role">Preferred Role / Department</label>
                  <input id="career-general-role" name="role" type="text" placeholder="Example: Sales, Production, QC" required />
                </div>

                <div class="col-md-6 career-application-form__field">
                  <label for="career-general-name">Full Name</label>
                  <input id="career-general-name" name="name" type="text" placeholder="Enter your full name" required />
                </div>

                <div class="col-md-6 career-application-form__field">
                  <label for="career-general-email">Email Address</label>
                  <input id="career-general-email" name="email" type="email" placeholder="Enter your email" required />
                </div>

                <div class="col-md-6 career-application-form__field">
                  <label for="career-general-phone">Contact Number</label>
                  <input id="career-general-phone" name="phone" type="tel" placeholder="Enter your contact number" required />
                </div>

                <div class="col-md-6 career-application-form__field">
                  <label for="career-general-experience">Experience</label>
                  <input id="career-general-experience" name="experience" type="text" placeholder="Example: Fresher or 3 years" required />
                </div>

                <div class="col-md-6 career-application-form__field">
                  <label for="career-general-city">Current City</label>
                  <input id="career-general-city" name="city" type="text" placeholder="Enter your current city" required />
                </div>

                <div class="col-12 career-application-form__field">
                  <label for="career-general-resume">Upload Resume</label>
                  <input id="career-general-resume" name="resume" type="file" accept=".pdf,.doc,.docx" required />
                  <small>Accepted formats: PDF, DOC, DOCX. Maximum file size: 5 MB.</small>
                </div>

                <div class="col-12 career-application-form__field">
                  <label for="career-general-message">Additional Details</label>
                  <textarea id="career-general-message" name="message" placeholder="Share the type of role, location, shift preference, or anything else we should know"></textarea>
                </div>

                <div class="col-12">
                  <div class="career-application-form__actions">
                    <button class="btn-quinary career-application-form__submit" type="submit">
                      <span class="btn-animated-text" data-text="Submit Profile">Submit Profile</span>
                    </button>
                    <p class="career-application-form__status" data-career-application-status role="status" aria-live="polite"></p>
                  </div>
                </div>
              </div>
            </form>
          </div>
        </div>
      </section>
    

    <script>
      (() => {
        const forms = document.querySelectorAll("[data-career-application-form]");
        if (!forms.length) return;

        forms.forEach((form) => {
          const status = form.querySelector("[data-career-application-status]");
          const button = form.querySelector("button[type='submit']");

          form.addEventListener("submit", async (event) => {
            event.preventDefault();

            status.textContent = "Submitting your profile...";
            status.className = "career-application-form__status is-pending";
            button.disabled = true;

            try {
              const response = await fetch(form.action, {
                method: "POST",
                body: new FormData(form),
                headers: {
                  Accept: "application/json"
                }
              });
              const result = await response.json();

              if (!response.ok || !result.success) {
                throw new Error(result.message || "Please check the form and try again.");
              }

              window.location.href = "/thank-you";
            } catch (error) {
              status.textContent = error.message || "Unable to submit your profile right now.";
              status.className = "career-application-form__status is-error";
            } finally {
              button.disabled = false;
            }
          });
        });
      })();
    </script>
