<section class="infra-hero">
        <div class="container-lg">
          <div class="infra-hero__content fade-up">
            <span class="infra-kicker">Pioneer </span>
            <h1 class="elicyon">Manufacturing </h1>
            <p>
              A large-scale Rudrapur plant supports Pioneer Flex production across signage media, self-adhesive vinyl, PVC foam board, fabric, and packaging systems.
            </p>
            <div class="infra-hero__actions">
              <a class="infra-btn" href="/contact-us">
                <i class="ti ti-message-2"></i>
                <span>Discuss Requirement</span>
              </a>
              <a class="infra-btn infra-btn--ghost" href="/e-catalogue">
                <i class="ti ti-file-download"></i>
                <span>View Catalogues</span>
              </a>
            </div>
          </div>
        </div>
      </section>

      <div class="container-lg">
        <nav class="infra-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span>/</span>
          <span class="current">Infrastructure</span>
        </nav>
      </div>

      <section class="infra-section">
        <div class="container-lg">
          <div class="infra-editorial">
            <div class="fade-up">
              <span class="infra-kicker">Rudrapur Plant</span>
              <h2 class="infra-title elicyon">Built for volume, consistency, and in-house control.</h2>
            </div>
            <div class="fade-up" data-delay="140">
              <p class="infra-copy">
                The manufacturing plant is spread across 1 million sq ft at SIDCUL Pantnagar, Rudrapur in Uttarakhand. The location supports a complete production ecosystem for modern PVC, signage, and industrial laminated products.
              </p>
              <p class="infra-copy">
                Production is supported by calendar lines, laminators, fabric preparation, self-adhesive vinyl systems, foam board lines, and in-house packaging material capability.
              </p>
            </div>
          </div>

          <div class="infra-stats">
            <div class="infra-stat fade-up">
              <strong><span class="odometer" data-odometer-final="1">0</span><span class="infra-stat__suffix">M</span></strong>
              <span>sq ft manufacturing footprint at SIDCUL Pantnagar, Rudrapur</span>
            </div>
            <div class="infra-stat fade-up" data-delay="100">
              <strong><span class="odometer" data-odometer-final="6">0</span><span class="infra-stat__suffix">+</span></strong>
              <span>fully automated PVC calendars for films and flex banner</span>
            </div>
            <div class="infra-stat fade-up" data-delay="200">
              <strong><span class="odometer" data-odometer-final="11">0</span></strong>
              <span>hot and cold laminating machines for flex banner quality</span>
            </div>
            <div class="infra-stat fade-up" data-delay="300">
              <strong><span class="odometer" data-odometer-final="17">0</span></strong>
              <span>knitting and warping fabric machines supporting in-house fabric</span>
            </div>
          </div>
        </div>
      </section>

      <!-- ==== infrastructure machines zigzag section start ==== -->
      <section
        class="decorative-services louver-story pt-140 pb-140 bg-alt-2"
        aria-labelledby="infrastructure-machines-title"
      >
        <div class="container-lg">
          <div class="row">
            <div class="col-12">
              <div class="decorative-services__header fade-up">
                <p class="txt-light">(Manufacturing Backbone)</p>
                <h2
                  class="decorative-services__title elicyon fw-3 mt-12"
                  id="infrastructure-machines-title"
                >
                  Machines That Power Pioneer Production
                </h2>
                <p class="decorative-services__intro txt-light">
                  Pioneer brings together PVC calendars, laminators, foam board
                  lines, fabric machinery, self-adhesive vinyl systems, and
                  in-house packing material production at its Rudrapur plant.
                </p>
              </div>
            </div>
          </div>

          <div class="decorative-services__list mt-60">
            <article class="decorative-services__item fade-up" data-delay="0">
              <div class="decorative-services__media">
                <img
                  src="assets/images/infrastructure/calendar.jpg"
                  alt="Calendar machine for PVC film production"
                  loading="lazy"
                />
              </div>
              <div class="decorative-services__content">
                <p class="txt-light">(PVC Film)</p>
                <h3 class="elicyon fw-3">Calendar Machines</h3>
                <p>
                  Pioneer has six fully automated PVC calendars to produce
                  best-in-class PVC film for Flex Banner, along with one
                  dedicated calendar to produce film for Self Adhesive Vinyl.
                  The calendars are equipped with Korean and Taiwanese
                  technical collaboration.
                </p>
              </div>
            </article>

            <article
              class="decorative-services__item decorative-services__item--reverse fade-up"
              data-delay="160"
            >
              <div class="decorative-services__media">
                <img
                  src="assets/images/infrastructure/laminator.jpg"
                  alt="Lamination machine for flex banner production"
                  loading="lazy"
                />
              </div>
              <div class="decorative-services__content">
                <p class="txt-light">(Flex Banner)</p>
                <h3 class="elicyon fw-3">Lamination Machines</h3>
                <p>
                  Pioneer has eleven hot and cold laminating machines imported
                  from renowned companies in Germany, Korea, and Taiwan to
                  produce high-quality Flex Banner.
                </p>
              </div>
            </article>

            <article class="decorative-services__item fade-up" data-delay="320">
              <div class="decorative-services__media">
                <img
                  src="assets/images/infrastructure/foam-board.jpg"
                  alt="PVC foam board production line"
                  loading="lazy"
                />
              </div>
              <div class="decorative-services__content">
                <p class="txt-light">(Rigid Boards)</p>
                <h3 class="elicyon fw-3">PVC Foam Board Lines</h3>
                <p>
                  Four dedicated lines produce PVC Foam Board for Pioneer’s
                  signage, display, and rigid board product requirements.
                </p>
              </div>
            </article>

            <article
              class="decorative-services__item decorative-services__item--reverse fade-up"
              data-delay="480"
            >
              <div class="decorative-services__media">
                <img
                  src="assets/images/infrastructure/fabric.jpg"
                  alt="Warp and knitted fabric machines"
                  loading="lazy"
                />
              </div>
              <div class="decorative-services__content">
                <p class="txt-light">(Fabric Base)</p>
                <h3 class="elicyon fw-3">Warp & Knitted Fabric</h3>
                <p>
                  Pioneer is equipped with thirteen knitting and four warping
                  fabric machines imported from Karl Mayer Liba, Germany. The
                  in-house knitted fabric is used to manufacture Flex Banner.
                </p>
              </div>
            </article>

            <article class="decorative-services__item fade-up" data-delay="640">
              <div class="decorative-services__media">
                <img
                  src="assets/images/infrastructure/vinyl.jpg"
                  alt="Self adhesive vinyl production equipment"
                  loading="lazy"
                />
              </div>
              <div class="decorative-services__content">
                <p class="txt-light">(Adhesive Media)</p>
                <h3 class="elicyon fw-3">Self-Adhesive Vinyl</h3>
                <p>
                  PE coating, silicon coating, a vinyl production line, and a
                  dedicated calendar work together to produce excellent-quality
                  Self Adhesive Vinyl.
                </p>
              </div>
            </article>

            <article
              class="decorative-services__item decorative-services__item--reverse fade-up"
              data-delay="800"
            >
              <div class="decorative-services__media">
                <img
                  src="assets/images/infrastructure/paper-tube.jpg"
                  alt="Paper tube and packaging material production"
                  loading="lazy"
                />
              </div>
              <div class="decorative-services__content">
                <p class="txt-light">(Dispatch Ready)</p>
                <h3 class="elicyon fw-3">Paper Tube & Packaging</h3>
                <p>
                  Paper tubes and hard covers used for Flex Banner packing are
                  produced in-house on indigenous machines, helping preserve
                  quality through the packing stage.
                </p>
              </div>
            </article>
          </div>
        </div>
      </section>
      <!-- ==== / infrastructure machines zigzag section end ==== -->

      <section class="infra-flow">
        <div class="container-lg">
          <div class="infra-editorial">
            <div class="fade-up">
              <span class="infra-kicker">How It Works</span>
              <h2 class="infra-title elicyon">A manufacturing flow designed for repeatable quality.</h2>
            </div>
            <div class="fade-up" data-delay="140">
              <p class="infra-copy">
                The plant brings core processes closer together, reducing handoffs and helping teams monitor material behavior from base preparation through finishing and packing.
              </p>
            </div>
          </div>

          <div class="infra-flow__steps">
            <article class="infra-step fade-up">
              <i class="ti ti-building-factory-2"></i>
              <h3>Film & Base Preparation</h3>
              <p>Calendar and fabric systems prepare the core material structure for signage and PVC applications.</p>
            </article>
            <article class="infra-step fade-up" data-delay="100">
              <i class="ti ti-layers-intersect"></i>
              <h3>Lamination & Coating</h3>
              <p>Hot, cold, PE, and silicon coating systems support flex banner and self-adhesive media requirements.</p>
            </article>
            <article class="infra-step fade-up" data-delay="200">
              <i class="ti ti-ruler-measure"></i>
              <h3>Board & Sheet Output</h3>
              <p>Dedicated PVC foam board lines extend the plant capability into rigid display and interior products.</p>
            </article>
            <article class="infra-step fade-up" data-delay="300">
              <i class="ti ti-package"></i>
              <h3>In-House Packing</h3>
              <p>Paper tubes and hard covers are made on-site so finished products remain protected in transit.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="ideas-inspiration infra-gallery pt-140 pb-140 bg-alt-2 bg-white" id="gallery-list">
        <div class="container-lg">
          <div class="row">
            <% galleryItems.forEach((item) => { %>
              <div class="col-lg-4">
                <%- include('../../partials/gallery-card', { item, galleryGroup: 'infrastructure-gallery' }) %>
              </div>
            <% }); %>
          </div>
        </div>
      </section>

