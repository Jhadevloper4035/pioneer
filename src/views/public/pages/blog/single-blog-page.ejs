<%- include('../../partials/page-hero', {
        tag: '(' + post.category + ')',
        title: post.title,
        text: 'Pioneer Flex product insight for practical interior, decorative, and manufacturing applications.',
        image: '/' + post.image,
        buttonText: 'Back to Blog',
        buttonLink: '/blog'
      }) %>

      <article class="journal-section pt-140 pb-100 bg-alt-2">
        <div class="container-lg">
          <div class="row justify-content-center">
            <div class="col-12 col-lg-9">
              <div class="fade-up">
                <img
                  src="/<%= post.image %>"
                  alt="<%= post.alt %>"
                  style="width: 100%; aspect-ratio: 16 / 9; object-fit: cover;"
                />
                <p class="section__content-sub-title mt-35"><%= post.category %></p>
                <h1 class="title-lg-sm elicyon fw-3 mt-12"><%= post.title %></h1>
                <p class="mt-24">
                  Pioneer Flex develops product categories for manufacturers, architects, contractors,
                  and interior teams that need consistent finish quality and practical site performance.
                </p>
                <p>
                  This category supports projects where material selection, surface finish, durability,
                  and dependable supply are important. Connect with the Pioneer team for samples,
                  catalogues, and product-specific guidance.
                </p>
                <a class="btn-quinary mt-35" href="/contact-us?subject=<%= encodeURIComponent(post.category) %>">
                  <span class="btn-animated-text" data-text="Enquire Now">Enquire Now</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </article>

      <% if (relatedPosts.length) { %>
        <section class="journal-section pt-80 pb-140 bg-alt-2">
          <div class="container-lg">
            <div class="section__header text-center mb-60">
              <p class="section__content-sub-title">More Articles</p>
              <h2 class="title-lg-sm elicyon fw-3 mt-12">Related insights</h2>
            </div>
            <div class="row gutter-30">
              <% relatedPosts.forEach((relatedPost) => { %>
                <div class="col-12 col-md-6 col-xl-4 fade-up">
                  <%- include('../../partials/blog-card', { post: relatedPost }) %>
                </div>
              <% }); %>
            </div>
          </div>
        </section>
      <% } %>
