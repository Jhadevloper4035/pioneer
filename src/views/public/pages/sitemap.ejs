
<main class="sitemap-section">
  <div class="container-lg">
    <div class="sitemap-section__header">
      <span class="about-kicker">Pioneer Decor</span>
      <h2 class="about-title elicyon">Explore every important page from one place.</h2>
      <p class="about-copy">
        Product categories, dynamic product detail pages, company information, catalogues, and policies are grouped below.
      </p>
    </div>
    <div class="sitemap-grid">
      <% sitemapSections.forEach((section) => { %>
        <article class="sitemap-card">
          <div class="sitemap-card__head">
            <h2><%= section.title %></h2>
            <span><%= section.links.length %></span>
          </div>
          <ul>
            <% section.links.forEach((link) => { %>
              <li><a href="<%= link.href %>"><%= link.label %></a></li>
            <% }); %>
          </ul>
        </article>
      <% }); %>
    </div>
  </div>
</main>
