<% const hasCategoryGrid=typeof showCategoryGrid !=="undefined" ? showCategoryGrid : true; const
  hasDecorativeZigzag=typeof showDecorativeZigzag !=="undefined" ? showDecorativeZigzag : false; const
  productCtaTarget="#products" ; const productCategoryLinks={ decorativeFilms: "/pvc-decorative-film" ,
  interiorLouvers: "/pvc-wpc-interior-louvers" , doors: "/wpc-doors" , frames: "/wpc-door-frames" , baffles: "/pvc-wpc-baffles" };
  const verticalSites=[ { title: "Signage" , href: "https://pioneerflex.in/" , label: "Large format media" }, {
  title: "Decorative" , href: "/" , label: "Interior surfaces" }, { title: "PVC Tapes" ,
  href: "https://pioneertapes.in/" , label: "Adhesive tapes" } ]; %>



  <!-- ==== hero section start ==== -->
  <section class="hero-three pb-140">
    <div class="container">
      <div class="row">
        <div class="col-12">
          <div class="hero-three__content">
            <div class="hero-three-slider swiper">
              <div class="swiper-wrapper">
                <div class="swiper-slide">
                  <div class="hero-three__single">
                    <h2 class="title-lg elicyon txt-light-fix">
                      PVC Decorative
                    </h2>
                    <h3 class="title-lg-sm fw-3 txt-light-fix">
                      films for modern interiors.
                    </h3>
                    <p class="txt-light-fix mt-30">
                      Premium decorative film finishes for furniture,
                      modular kitchens, wardrobes, counters, and membrane
                      door applications.
                    </p>
                    <div class="hero-three__cta">
                      <a class="btn-quinary" href="<%= productCtaTarget %>">
                        <span class="btn-animated-text" data-text="View Products">View Products</span>
                      </a>
                    </div>
                  </div>
                </div>
                <div class="swiper-slide">
                  <div class="hero-three__single">
                    <h2 class="title-lg elicyon txt-light-fix">
                      PVC/WPC Interior
                    </h2>
                    <h3 class="title-lg-sm fw-3 txt-light-fix">
                      louvers for modern interiors.
                    </h3>
                    <p class="txt-light-fix mt-30">
                      PVC/WPC interior louvers that add depth,
                      texture, and clean finishing to feature walls,
                      partitions, retail, and commercial interiors.
                    </p>
                    <div class="hero-three__cta">
                      <a class="btn-quinary" href="<%= productCtaTarget %>">
                        <span class="btn-animated-text" data-text="View Products">View Products</span>
                      </a>
                    </div>
                  </div>
                </div>
                <div class="swiper-slide">
                  <div class="hero-three__single">
                    <h2 class="title-lg elicyon txt-light-fix">
                      WPC Doors
                    </h2>
                    <h3 class="title-lg-sm fw-3 txt-light-fix">
                      and frames built for stability.
                    </h3>
                    <p class="txt-light-fix mt-30">
                      Moisture-resistant WPC frames made for dependable
                      fitment in homes, offices, hotels, showrooms, and
                      institutional projects.
                    </p>
                    <div class="hero-three__cta">
                      <a class="btn-quinary" href="<%= productCtaTarget %>">
                        <span class="btn-animated-text" data-text="View Products">View Products</span>
                      </a>
                    </div>
                  </div>
                </div>

                <div class="swiper-slide">
                  <div class="hero-three__single">
                    <h2 class="title-lg elicyon txt-light-fix">
                      PVC/WPC
                    </h2>
                    <h3 class="title-lg-sm fw-3 txt-light-fix">
                      baffles for statement spaces.
                    </h3>
                    <p class="txt-light-fix mt-30">
                      Decorative baffle systems for ceilings, screens,
                      partitions, facades, and feature zones that need
                      rhythm, texture, and durable finish quality.
                    </p>
                    <div class="hero-three__cta">
                      <a class="btn-quinary" href="<%= productCtaTarget %>">
                        <span class="btn-animated-text" data-text="View Products">View Products</span>
                      </a>
                    </div>
                  </div>
                </div>

              </div>
            </div>
            <div class="slider-navigation">
              <button type="button" aria-label="prev slide" title="prev slide" class="prev-hero">
                <i class="ph ph-arrow-up-left"></i>
              </button>
              <button type="button" aria-label="next slide" title="next slide" class="next-hero">
                <i class="ph ph-arrow-down-right"></i>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="hero-three-bg">
      <img src="assets/images/banner/pvc-decorative-firms.avif"
        alt="Interior finished with Pioneer PVC decorative films" class="active-bg" />
      <img src="assets/images/banner/pvc-wpc-interior-bg.jpeg" alt="Pioneer PVC WPC wall panel and louver interior" />
      <img src="assets/images/banner/wpc-doors-bg.jpeg" alt="Pioneer WPC Doors interior application" />
      <img src="assets/images/banner/baffles-bg.jpeg" alt="Pioneer PVC WPC baffle screen application" />
    </div>
  </section>
  <!-- ==== / hero section end ==== -->

  <section class="main-category-section pt-100 pb-80 bg-alt-2" id="products">
    <div class="container-lg">

      <div class="main-category-section__grid mt-60">
        <a class="main-category-section__item fade-up" href="<%= productCategoryLinks.decorativeFilms %>"
          aria-label="View PVC Decorative Films category">
          <img src="assets/images/banner/pvc-wpc-interior-lovers.jpeg"
            alt="Interior finished with Pioneer PVC decorative films" />
          <div class="main-category-section__content">
            <p>Furniture &amp; membrane finishes</p>
            <h2>PVC Decorative Films</h2>
            <span>View Category</span>
          </div>
        </a>
        <a class="main-category-section__item fade-up" href="<%= productCategoryLinks.interiorLouvers %>"
          data-delay="100" aria-label="View PVC WPC Interior Louvers category">
          <img src="assets/images/banner/pvc-decor-frame.jpeg" alt="Interior with Pioneer PVC WPC interior louvers" />
          <div class="main-category-section__content">
            <p>Interior louvers</p>
            <h2>PVC/WPC Interior Louvers</h2>
            <span>View Category</span>
          </div>
        </a>
        <a class="main-category-section__item fade-up" href="<%= productCategoryLinks.doors %>" data-delay="200"
          aria-label="View WPC Doors category">
          <img src="assets/images/banner/pvc-door-frame.jpeg"
            alt="Interior application for Pioneer WPC Doors" />
          <div class="main-category-section__content">
            <p>Stable door systems</p>
            <h2>WPC Doors</h2>
            <span>View Category</span>
          </div>
        </a>
        <a class="main-category-section__item fade-up" href="<%= productCategoryLinks.frames %>" data-delay="250"
          aria-label="View WPC Door Frames category">
          <img src="assets/images/projects/wpc-door-frame.jpeg"
            alt="Pioneer WPC door frame interior application" />
          <div class="main-category-section__content">
            <p>Moisture-resistant frames</p>
            <h2>WPC Door Frames</h2>
            <span>View Category</span>
          </div>
        </a>
        <a class="main-category-section__item fade-up" href="<%= productCategoryLinks.baffles %>" data-delay="300"
          aria-label="View PVC WPC Baffles category">
          <img src="assets/images/banner/baffles.jpeg" alt="Pioneer PVC WPC baffle screen application" />
          <div class="main-category-section__content">
            <p>Ceiling &amp; screen systems</p>
            <h2>PVC/WPC Baffles</h2>
            <span>Know More</span>
          </div>
        </a>
      </div>
    </div>
  </section>
  <!-- ==== / product category showcase end ==== -->

  <section class="vertical-sites" data-background="assets/images/banner/banner1.webp"
    aria-label="Pioneer vertical websites">
    <div class="container-lg">
      <div class="vertical-sites__panel fade-up">
        <div class="vertical-sites__brand">
          <img src="assets/images/logo/logo.png" alt="Pioneer" />
          <span>Flex</span>
        </div>
        <div class="vertical-sites__links">
          <% verticalSites.forEach((site)=> { %>
            <a class="vertical-sites__link" href="<%= site.href %>" <%- site.href.startsWith("http")
              ? 'target="_blank" rel="noopener"' : "" %>>
              <small>
                <%= site.label %>
              </small>
              <span>
                <%= site.title %>
              </span>
            </a>
            <% }) %>
        </div>
      </div>
    </div>
  </section>


  <!-- ==== about section start ==== -->
  <section class="about-three pt-140 pb-140 template-bg scale-wrapper" id="about">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 col-md-10 col-lg-8 col-xl-8">
          <div class="about-three__header mb-80">
            <h2 class="title-animation text-center title-lg-sm fw-5 elicyon">
              Where
              <!-- <span class="line"></span> -->
              <span class="text-uppercase">PVC innovation</span>
              meets manufacturing strength
            </h2>
            <p class="mt-30 title-animation text-center txt-light">
              Pioneer Décor is a vertical of Pioneer Polyleathers (P) Limited. Pioneer is a Leading PVC Processing
              Company operating since 2008. Pioneer is the Market Leader of Different PVC Materials like in large format
              Signage products.
            </p>
          </div>
        </div>
      </div>
    </div>
    <div class="container-lg">
      <div class="row gutter-40">
        <div class="col-12 col-md-7 col-lg-7">
          <div class="about-three__thumb-wrapper">
            <div class="about-three__thumb hover-image scale-up" data-displacement="assets/images/about/side.jpg"
              data-intensity="0.2" data-speedin="1" data-speedout="1">
              <img src="assets/images/about/side.jpg" alt="Image" class="flip-img" />
            </div>
          </div>
        </div>
        <div class="col-12 col-md-5 col-lg-5">
          <div class="about-three__content-wrapper">
            <div class="about-three-sm-thumb hover-image scale-up" data-displacement="assets/images/bg-one.webp"
              data-intensity="0.2" data-speedin="1" data-speedout="1">
              <img src="assets/images/about/about-detail.jpeg" alt="Image" class="flip-img" />
            </div>
            <div class="about-three__content">
              <p class="mt-40 title-animation txt-light">
                After establishing itself in the Signage market, Pioneer
                has now launched new vertical “Pioneer Décor” with a
                wide range of Products like PVC Louvers (Wall Panels),
                Decorative PVC Self Adhesive Films, PVC Films for
                Doors, Furniture, Cabinets, PVC Laminate, Acrylic
                Laminate, PVC/WPC Wall Panel, SPC, LVT etc
              </p>
              <a class="btn-quinary about-three__content-cta mt-35" href="/about-company">
                <span class="btn-animated-text" data-text="Read More">Read More</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- ==== / about section end ==== -->

  <!-- ==== parallax cta section start ==== -->
  <section class="parallax-cta">
    <div class="parallax-cta__bg" data-background="assets/images/infrastructure/banner.jpg"></div>
    <div class="container-lg">
      <div class="row">
        <div class="col-12">
          <div class="parallax-cta__content fade-up">
            <p class="txt-light-4">(Make in India Manufacturing)</p>
            <h2 class="title-animation elicyon fw-3">
              Every component is produced locally through integrated plant
