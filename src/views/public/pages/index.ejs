  <!-- ==== home video section start ==== -->
  <section class="home-video pt-100 pb-140 bg-alt-2">
    <div class="container-lg">
      <div class="home-video__frame fade-up mt-60" data-delay="160">
        <video autoplay muted loop playsinline preload="metadata" poster="assets/images/wpc-louvers/1.jpeg"
          aria-label="Pioneer decorative louver application video">
          <source src="https://rantechnology.in/pioneer/video.mp4" type="video/mp4" />
        </video>
      </div>
    </div>
  </section>
  <!-- ==== / home video section end ==== -->


  <!-- ==== quote form section start ==== -->
  <section class="quote-maker pt-100 pb-100 template-bg bg-white">
    <div class="container-lg">
      <div class="row">
        <div class="col-12">
          <div class="quote-maker__intro text-center fade-up">
            <p class="txt-light">(Enquire Now)</p>
            <h2 class="title-animation title-lg-sm elicyon fw-3 mt-12">
              Make an Inquiry
            </h2>
          </div>
          <form class="quote-maker__form fade-up mt-80" action="#" method="post">
            <div class="quote-maker__grid">
              <div class="quote-maker__field">
                <input type="text" name="quote-name" id="quoteName" placeholder="Name *" required />
              </div>
              <div class="quote-maker__field">
                <input type="tel" name="quote-mobile" id="quoteMobile" placeholder="Mobile *" required />
              </div>
              <div class="quote-maker__field">
                <input type="email" name="quote-email" id="quoteEmail" placeholder="Email *" required />
              </div>
              <div class="quote-maker__field">
                <input type="text" name="quote-city" id="quoteCity" placeholder="City *" required />
              </div>
              <div class="quote-maker__stack">
                <div class="quote-maker__field">
                  <label for="quoteProduct">Select Product *</label>
                  <select name="quote-product" id="quoteProduct" required>
                    <option value="PVC Decorative Films">
                      PVC Decorative Films
                    </option>
                    <option value="PVC/WPC Interior Louvers">
                      PVC/WPC Interior Louvers
                    </option>
                    <option value="WPC Doors">
                      WPC Doors
                    </option>
                    <option value="WPC Door Frames">
                      WPC Door Frames
                    </option>
                    <option value="PVC/WPC Baffles">
                      PVC/WPC Baffles
                    </option>
                  </select>
                </div>
                <div class="quote-maker__split">
                  <div class="quote-maker__field">
                    <label for="quoteQuantity">Approximate Quantity Required *</label>
                    <select name="quote-quantity" id="quoteQuantity" required>
                      <option value="100-500">100-500</option>
                      <option value="500-1000">500-1000</option>
                      <option value="1000+">1000+</option>
                    </select>
                  </div>
                  <div class="quote-maker__field">
                    <label for="quoteUnit">Unit *</label>
                    <select name="quote-unit" id="quoteUnit" required>
                      <option value="">Select</option>
                      <option value="Sq. Ft.">Sq. Ft.</option>
                      <option value="Sq. M.">Sq. M.</option>
                      <option value="Pieces">Pieces</option>
                    </select>
                  </div>
                </div>
                <div class="quote-maker__field">
                  <label for="quoteApplication">Application *</label>
                  <select name="quote-application" id="quoteApplication" required>
                    <option value="">Select an option</option>
                    <option value="Signage">Signage</option>
                    <option value="Furniture / Home Decor">
                      Furniture / Home Decor
                    </option>
                    <option value="Industrial">Industrial</option>
                    <option value="Distribution">Distribution</option>
                    <option value="Export">Export</option>
                  </select>
                </div>
              </div>
              <div class="quote-maker__field quote-maker__field--textarea">
                <textarea name="quote-comments" id="quoteComments" placeholder="Comments"></textarea>
              </div>
            </div>
            <div class="quote-maker__cta text-center mt-80">
              <button type="submit" class="btn-primary" aria-label="Send quote request" title="Send quote request">
                <span class="btn-animated-text" data-text="Send">Send</span>
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
  <!-- ==== / quote form section end ==== -->

  <!-- ==== journal section start ==== -->
  <section class="journal-section pt-140 pb-140 template-bg">
    <div class="container-lg">
      <div class="row">
        <div class="col-12">
          <div class="journal-section__header fade-up">
            <div>
              <p class="txt-light">(Latest Notes)</p>
              <h2 class="title-animation title-lg-sm elicyon fw-3 mt-12">
                Journal
              </h2>
            </div>
          </div>
          <div class="journal-section__slider swiper mt-60 fade-up">
            <div class="swiper-wrapper">
              <% blogPosts.forEach((post)=> { %>
                <div class="swiper-slide">
                  <%- include('../partials/blog-card', { post }) %>
                </div>
                <% }); %>
            </div>
          </div>
          <div class="journal-section__navigation fade-up mt-60">
            <button type="button" class="journal-prev" aria-label="Previous journal" title="Previous journal">
              <img src="assets/images/left-arrow.webp" alt="Image" />
            </button>
            <button type="button" class="journal-next" aria-label="Next journal" title="Next journal">
              <img src="assets/images/right-arrow.webp" alt="Image" />
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>
