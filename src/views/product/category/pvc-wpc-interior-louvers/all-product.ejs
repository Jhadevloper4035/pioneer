            id="louver-lightbox-image"
            src=""
            alt=""
          />
        </div>
        <button
          class="louver-image-lightbox__nav louver-image-lightbox__nav--prev"
          type="button"
          data-lightbox-prev
          aria-label="View previous image"
        >
          &#8592;
        </button>
        <button
          class="louver-image-lightbox__nav louver-image-lightbox__nav--next"
          type="button"
          data-lightbox-next
          aria-label="View next image"
        >
          &#8594;
        </button>
        <button
          class="louver-image-lightbox__close"
          type="button"
          data-lightbox-close
          aria-label="Close image preview"
