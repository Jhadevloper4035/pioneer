<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="shortcut icon" href="/assets/images/favicon.webp" type="image/x-icon" />
    <title><%= category.title %> | Pioneer Flex</title>
    <meta name="description" content="<%= category.text %>" />
    <link rel="stylesheet" href="/assets/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/assets/fonts/css/all.min.css" />
    <link rel="stylesheet" href="/assets/fonts/css/tabler-icons.min.css" />
    <link rel="stylesheet" href="/assets/css/main.css" />
  </head>
  <body>
    <div class="page-wrapper">
      <%- include('../../../partials/header') %>
      <%- include('../../../partials/page-hero', {
        tag: category.tag,
        title: category.title,
        text: category.text,
        image: category.image,
        buttonText: 'View Category',
        buttonLink: '#' + (category.anchor || 'category-heading')
      }) %>
      <section class="pt-120 pb-120 bg-alt-2">
        <div class="container-lg text-center">
          <p class="section__content-sub-title">(Product Category)</p>
          <h2 class="title-lg-sm elicyon fw-3 mt-12" id="<%= category.anchor || 'category-heading' %>"><%= category.title %></h2>
          <p class="mt-24 mx-auto" style="max-width: 680px;"><%= category.text %></p>
          <a class="btn-quinary mt-35" href="/contact-us?subject=<%= encodeURIComponent(category.title) %>">
            <span class="btn-animated-text" data-text="Request Details">Request Details</span>
          </a>
        </div>
      </section>
      <%- include('../../../partials/footer') %>
    </div>
    <script src="/assets/js/jquery-3.7.1.min.js"></script>
    <script src="/assets/js/bootstrap.bundle.min.js"></script>
    <script src="/assets/js/custom.js"></script>
  </body>
</html>
