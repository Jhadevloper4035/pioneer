<!doctype html>
<html lang="en">
  <head>
    <!-- required meta -->
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- #favicon -->
    <link
      rel="shortcut icon"
      href="assets/images/favicon.webp"
      type="image/x-icon"
    />
    <link rel="icon" href="assets/images/favicon.webp" type="image/x-icon" />
    <!-- #title -->
    <title>
      Pioneer Flex | PVC Processing, Signage, Decorative Films & Industrial
      Products
    </title>
    <!-- #keywords -->
    <meta
      name="keywords"
      content="pvc processing, flex banner, signage, pvc films, decorative laminates, pvc tapes, industrial products"
    />
    <!-- #description -->
    <meta
      name="description"
      content="Pioneer Polyleathers is a leading PVC processing company offering signage products, decorative films, PVC tapes, and industrial laminated products."
    />
    <!-- bootstrap five css -->
    <link rel="stylesheet" href="assets/css/bootstrap.min.css" />
    <!-- font awesome six css -->
    <link rel="stylesheet" href="assets/fonts/css/all.min.css" />
    <!-- tabler icons css -->
    <link rel="stylesheet" href="assets/fonts/css/tabler-icons.min.css" />
    <!-- magnific popup css -->
    <link rel="stylesheet" href="assets/css/magnific-popup.css" />
    <!-- nice select css -->
    <link rel="stylesheet" href="assets/css/nice-select.css" />
    <!-- odometer css -->
    <link rel="stylesheet" href="assets/css/odometer.css" />
    <!-- swiper slider css -->
    <link rel="stylesheet" href="assets/css/swiper-bundle.min.css" />
    <!-- main css -->
    <link rel="stylesheet" href="assets/css/main.css" />
    <link rel="stylesheet" href="assets/css/product.css" />
    <link rel="stylesheet" href="assets/css/louvers.css" />
    <link rel="stylesheet" href="assets/css/image-lightbox.css?v=1" />
  </head>

  <body>
    <%
      const hasCategoryGrid = typeof showCategoryGrid !== "undefined" ? showCategoryGrid : true;
      const hasDecorativeZigzag = typeof showDecorativeZigzag !== "undefined" ? showDecorativeZigzag : false;
      const productCtaTarget = "#products";
      const categoryDetailBase = hasDecorativeZigzag ? "" : "/home-zigzag";
    %>
    <div class="page-wrapper">
      <%- include('partials/header') %>
      <!-- ==== hero section start ==== -->
      <section class="hero-three pb-140">
        <div class="container">
          <div class="row">
            <div class="col-12">
              <div class="hero-three__content">
                <div class="hero-three-slider swiper">
                  <div class="swiper-wrapper">
                    <div class="swiper-slide">
                      <div class="hero-three__single">
                        <h2 class="title-lg elicyon txt-light-fix">
                          PVC Decorative
                        </h2>
                        <h3 class="title-lg-sm fw-3 txt-light-fix">
                          films for modern interiors.
                        </h3>
                        <p class="txt-light-fix mt-30">
                          Premium decorative film finishes for furniture,
                          modular kitchens, wardrobes, counters, and membrane
                          door applications.
                        </p>
                        <div class="hero-three__cta">
                          <a class="btn-quinary" href="<%= productCtaTarget %>">
                            <span
                              class="btn-animated-text"
                              data-text="View Products"
                              >View Products</span
                            >
                          </a>
                        </div>
                      </div>
                    </div>
                    <div class="swiper-slide">
                      <div class="hero-three__single">
                        <h2 class="title-lg elicyon txt-light-fix">
                          PVC/WPC Interior
                        </h2>
                        <h3 class="title-lg-sm fw-3 txt-light-fix">
                          louvers for modern interiors.
                        </h3>
                        <p class="txt-light-fix mt-30">
                          PVC/WPC interior louvers that add depth,
                          texture, and clean finishing to feature walls,
                          partitions, retail, and commercial interiors.
                        </p>
                        <div class="hero-three__cta">
                          <a class="btn-quinary" href="<%= productCtaTarget %>">
                            <span
                              class="btn-animated-text"
                              data-text="View Products"
                              >View Products</span
                            >
                          </a>
                        </div>
                      </div>
                    </div>
                    <div class="swiper-slide">
                      <div class="hero-three__single">
                        <h2 class="title-lg elicyon txt-light-fix">
                          WPC Doors
                        </h2>
                        <h3 class="title-lg-sm fw-3 txt-light-fix">
                          and frames built for stability.
                        </h3>
                        <p class="txt-light-fix mt-30">
                          Moisture-resistant WPC frames made for dependable
                          fitment in homes, offices, hotels, showrooms, and
                          institutional projects.
                        </p>
                        <div class="hero-three__cta">
                          <a class="btn-quinary" href="<%= productCtaTarget %>">
                            <span
                              class="btn-animated-text"
                              data-text="View Products"
                              >View Products</span
                            >
                          </a>
                        </div>
                      </div>
                    </div>

                    <div class="swiper-slide">
                      <div class="hero-three__single">
                        <h2 class="title-lg elicyon txt-light-fix">
                          PVC/WPC
                        </h2>
                        <h3 class="title-lg-sm fw-3 txt-light-fix">
                          baffles for statement spaces.
                        </h3>
                        <p class="txt-light-fix mt-30">
                          Decorative baffle systems for ceilings, screens,
                          partitions, facades, and feature zones that need
                          rhythm, texture, and durable finish quality.
                        </p>
                        <div class="hero-three__cta">
                          <a class="btn-quinary" href="<%= productCtaTarget %>">
                            <span
                              class="btn-animated-text"
                              data-text="View Products"
                              >View Products</span
                            >
                          </a>
                        </div>
                      </div>
                    </div>

                  </div>
                </div>
                <div class="slider-navigation">
                  <button
                    type="button"
                    aria-label="prev slide"
                    title="prev slide"
                    class="prev-hero"
                  >
                    <i class="ph ph-arrow-up-left"></i>
                  </button>
                  <button
                    type="button"
                    aria-label="next slide"
                    title="next slide"
                    class="next-hero"
                  >
                    <i class="ph ph-arrow-down-right"></i>
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="hero-three-bg">
          <img
            src="assets/images/banner/pvc-decorative-firms.avif"
            alt="Interior finished with Pioneer PVC decorative films"
            class="active-bg"
          />
          <img
            src="assets/images/banner/pvc-wpc-interior-bg.jpeg"
            alt="Pioneer PVC WPC wall panel and louver interior"
          />
          <img
            src="assets/images/banner/wpc-doors-bg.jpeg"
            alt="Pioneer WPC Doors and Frames interior application"
          />
          <img
            src="assets/images/banner/baffles-bg.jpeg"
            alt="Pioneer PVC WPC baffle screen application"
          />
        </div>
      </section>
      <!-- ==== / hero section end ==== -->

      <% if (hasCategoryGrid) { %>
      <!-- ==== product category showcase start ==== -->
      <section
        class="main-category-section pt-100 pb-80 bg-alt-2"
        id="products"
      >
        <div class="container-lg">
          <div class="row align-items-end gutter-30">
            <div class="col-12 col-lg-7">
              <div class="main-category-section__header fade-up">
                <p class="txt-light">(Product Categories)</p>
                <h2 class="main-category-section__title title-animation title-lg-sm elicyon fw-3 mt-12">
                  Find the right Pioneer surface at a glance
                </h2>
              </div>
            </div>
            <div class="col-12 col-lg-5">
              <p class="main-category-section__intro fade-up">
                Four focused categories for decorative interiors, wall systems,
                stable frames, and linear baffle applications.
              </p>
            </div>
          </div>

          <div class="main-category-section__grid mt-60">
            <a
              class="main-category-section__item fade-up"
              href="<%= categoryDetailBase %>#pvc-decorative-films"
              aria-label="View PVC Decorative Films category"
            >
              <img
                src="assets/images/category/pvc-decor-frame.webp"
                alt="Interior finished with Pioneer PVC decorative films"
              />
              <div class="main-category-section__content">
                <p>Furniture &amp; membrane finishes</p>
                <h2>PVC Decorative Films</h2>
                <span>View Category</span>
              </div>
            </a>
            <a
              class="main-category-section__item fade-up"
              href="<%= categoryDetailBase %>#pvc-wpc-wall-panels"
              data-delay="100"
              aria-label="View PVC WPC Interior Louvers category"
            >
              <img
                src="assets/images/category/pvc-wpc-interior-lovers.webp"
                alt="Interior with Pioneer PVC WPC interior louvers"
              />
              <div class="main-category-section__content">
                <p>Interior louvers</p>
                <h2>PVC/WPC Interior Louvers</h2>
                <span>View Category</span>
              </div>
            </a>
            <a
              class="main-category-section__item fade-up"
              href="<%= categoryDetailBase %>#wpc-door-frames"
              data-delay="200"
              aria-label="View WPC Doors and Frames category"
            >
              <img
                src="assets/images/category/pvc-door-frame.jpeg"
                alt="Interior application for Pioneer WPC Doors and Frames"
              />
              <div class="main-category-section__content">
                <p>Stable door systems</p>
                <h2>WPC Doors and Frames</h2>
                <span>View Category</span>
              </div>
            </a>
            <a
              class="main-category-section__item fade-up"
              href="<%= categoryDetailBase %>#pvc-wpc-baffles"
              data-delay="300"
              aria-label="View PVC WPC Baffles category"
            >
              <img
                src="assets/images/category/baffles.jpeg"
                alt="Pioneer PVC WPC baffle screen application"
              />
              <div class="main-category-section__content">
                <p>Ceiling &amp; screen systems</p>
                <h2>PVC/WPC Baffles</h2>
                <span>Know More</span>
              </div>
            </a>
          </div>
        </div>
      </section>
      <!-- ==== / product category showcase end ==== -->
      <% } %>

      <% if (hasDecorativeZigzag) { %>
      <!-- ==== decorative services zigzag section start ==== -->
      <section class="decorative-services louver-story pt-140 pb-140 bg-alt-2" id="products">
        <div class="container-lg">
          <div class="row">
            <div class="col-12">
              <div class="decorative-services__header fade-up">
                <p class="txt-light">(Pioneer Range)</p>
                <h2
                  class="decorative-services__title title-animation elicyon fw-3 mt-12"
                >
                  Decorative Product Range
                </h2>
                <p class="decorative-services__intro txt-light">
                  Premium PVC and WPC surfaces for furniture, walls, frames, and
                  doors with consistent finish quality.
                </p>
              </div>
            </div>
          </div>
          <div class="decorative-services__list mt-60">
            <article
              class="decorative-services__item fade-up"
              id="pvc-decorative-films"
              data-delay="0"
            >
              <div class="decorative-services__media">
                <img
                  src="assets/images/category/pvc-decor-frame.webp"
                  alt="PVC decorative film service"
                />
              </div>
              <div class="decorative-services__content">
                <p class="txt-light">(Furniture &amp; Membrane Films)</p>
                <h3 class="elicyon fw-3">PVC Decorative Films</h3>
                <p>
                  Decorative film finishes for furniture, modular kitchens,
                  membrane doors, wardrobes, counters, and interior panels.
                </p>
                <p>
                  Our film range helps manufacturers deliver coordinated
                  interior surfaces with dependable shade consistency and
                  finishes suited for daily residential and commercial use.
                </p>
                <a
                  class="btn-primary decorative-services__cta"
                  href="/wpc-louvers"
                >
                  <span class="btn-animated-text" data-text="View Details"
                    >View Details</span
                  >
                </a>
              </div>
            </article>
            <article
              class="decorative-services__item decorative-services__item--reverse fade-up"
              id="pvc-wpc-wall-panels"
              data-delay="160"
            >
              <div class="decorative-services__media">
                <img
                  src="assets/images/category/pvc-wpc-interior-lovers.webp"
                  alt="PVC WPC interior louver service"
                />
              </div>
              <div class="decorative-services__content">
                <p class="txt-light">(Interior Louvers)</p>
                <h3 class="elicyon fw-3">PVC/WPC Interior Louvers</h3>
                <p>
                  Interior louvers for feature walls, partitions,
                  corridors, retail interiors, and commercial decorative use.
                </p>
                <p>
                  These profiles bring depth and texture to walls while helping
                  teams complete decorative cladding work with cleaner handling
                  and predictable project timelines.
                </p>
                <a
                  class="btn-primary decorative-services__cta"
                  href="/wpc-louvers"
                >
                  <span class="btn-animated-text" data-text="View Details"
                    >View Details</span
                  >
                </a>
              </div>
            </article>
            <article
              class="decorative-services__item fade-up"
              id="wpc-door-frames"
              data-delay="320"
            >
              <div class="decorative-services__media">
                <img
                  src="assets/images/category/pvc-door-frame.jpeg"
                  alt="WPC doors and frames service"
                />
              </div>
              <div class="decorative-services__content">
                <p class="txt-light">(Stable Door Systems)</p>
                <h3 class="elicyon fw-3">WPC Doors and Frames</h3>
                <p>
                  Moisture-resistant WPC frames made for dependable fitment in
                  homes, offices, hotels, showrooms, and institutional projects.
                </p>
                <p>
                  The frames are developed for steady installation performance,
                  helping contractors reduce site issues while pairing well with
                  modern decorative door finishes.
                </p>
                <a
                  class="btn-primary decorative-services__cta"
                  href="#wpc-door-frames"
                >
                  <span class="btn-animated-text" data-text="View Details"
                    >View Details</span
                  >
                </a>
              </div>
            </article>
            <article
              class="decorative-services__item decorative-services__item--reverse fade-up"
              id="pvc-wpc-baffles"
              data-delay="480"
            >
              <div class="decorative-services__media">
                <img
                  src="assets/images/category/baffles.jpeg"
                  alt="PVC WPC baffle screen service"
                />
              </div>
              <div class="decorative-services__content">
                <p class="txt-light">(Ceiling &amp; Screen Systems)</p>
                <h3 class="elicyon fw-3">PVC/WPC Baffles</h3>
                <p>
                  Decorative baffles for ceilings, partitions, facades, and
                  feature screens with a clean linear profile.
                </p>
                <p>
                  These systems help designers add rhythm, shade, and texture
                  while keeping installation practical for residential,
                  commercial, and hospitality projects.
                </p>
                <a
                  class="btn-primary decorative-services__cta"
                  href="#pvc-wpc-baffles"
                >
                  <span class="btn-animated-text" data-text="View Details"
                    >View Details</span
                  >
                </a>
              </div>
            </article>
          </div>
        </div>
      </section>
      <!-- ==== / decorative services zigzag section end ==== -->
      <% } %>

      <!-- ==== about section start ==== -->
      <section
        class="about-three pt-140 pb-140 template-bg scale-wrapper"
        id="about"
      >
        <div class="container">
          <div class="row justify-content-center">
            <div class="col-12 col-md-10 col-lg-8 col-xl-8">
              <div class="about-three__header mb-80">
                <h2
                  class="title-animation text-center title-lg-sm fw-5 elicyon"
                >
                  Where
                  <!-- <span class="line"></span> -->
                  <span class="text-uppercase">PVC innovation</span>
                  meets manufacturing strength
                </h2>
                <p class="mt-30 title-animation text-center txt-light">
                  Pioneer Polyleathers (P) Limited is a leading PVC processing
                  company established in 2008, serving signage, home decor, PVC
                  tapes, and industrial markets with integrated production.
                </p>
              </div>
            </div>
          </div>
        </div>
        <div class="container-lg">
          <div class="row gutter-40">
            <div class="col-12 col-md-7 col-lg-7">
              <div class="about-three__thumb-wrapper">
                <div
                  class="about-three__thumb hover-image scale-up"
                  data-displacement="assets/images/bg-one.webp"
                  data-intensity="0.2"
                  data-speedin="1"
                  data-speedout="1"
                >
                  <img
                    src="assets/images/about/about.webp"
                    alt="Image"
                    class="flip-img"
                  />
                </div>
              </div>
            </div>
            <div class="col-12 col-md-5 col-lg-5">
              <div class="about-three__content-wrapper">
                <div
                  class="about-three-sm-thumb hover-image scale-up"
                  data-displacement="assets/images/bg-one.webp"
                  data-intensity="0.2"
                  data-speedin="1"
                  data-speedout="1"
                >
                  <img
                    src="assets/images/about/about-detail.jpeg"
                    alt="Image"
                    class="flip-img"
                  />
                </div>
                <div class="about-three__content">
                  <a href="#about">
                    <img src="assets/images/arrow-3.webp" alt="Image" />
                  </a>
                  <p class="mt-40 title-animation txt-light">
                    Pioneer operates a state-of-the-art manufacturing facility
                    spread across 6,55,000 sq. ft. at SIDCUL Pantnagar,
                    Rudrapur, Uttarakhand.
                  </p>
                  <p class="mt-30 title-animation txt-light">
                    With cutting-edge machinery, skilled technicians, and
                    reputed raw-material partners, we manufacture key components
                    in-house to control quality, consistency, and scale.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
      <!-- ==== / about section end ==== -->

      <!-- ==== parallax cta section start ==== -->
      <section class="parallax-cta">
        <div
          class="parallax-cta__bg"
          data-background="assets/images/infrastructure/banner.jpg"
        ></div>
        <div class="container-lg">
          <div class="row">
            <div class="col-12">
              <div class="parallax-cta__content fade-up">
                <p class="txt-light-4">(Make in India Manufacturing)</p>
                <h2 class="title-animation elicyon fw-3">
                  Every component is produced locally through integrated plant
                  operations, modern machinery, and skilled technicians.
                </h2>
                <a class="btn-quinary mt-20" href="/infrastructure">
                  <span
                    class="btn-animated-text"
                    data-text="View Infrastructure"
                    >View Infrastructure</span
                  >
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>
      <!-- ==== / parallax cta section end ==== -->

      <section class="why-choose pt-140 pb-140 template-bg">
        <div class="container-lg">
          <div class="row align-items-end gutter-30">
            <div class="col-12 col-lg-7">
              <div class="ideas-inspiration__intro fade-up">
                <p class="txt-light">(Work Process)</p>
                <h2 class="title-animation title-lg-sm elicyon fw-3 mt-12">
                  Explore ideas shaped for modern living
                </h2>
              </div>
            </div>
            <div class="col-12 col-lg-5">
              <p class="ideas-inspiration__text txt-light fade-up">
                Explore Pioneer product applications across signage, decorative
                surfaces, adhesive tapes, and industrial PVC laminated use
                cases.
              </p>
            </div>
          </div>
          <div class="why-choose__grid mt-80">
            <article class="why-choose__single1 fade-up">
              <div>
                <img
                  src="assets/images/work-process/sourcing.jpeg"
                  alt="Raw material and packaging inputs prepared for Pioneer PVC production"
                />
              </div>
              <h3>Sourcing</h3>
              <p>
                Pioneer works with internationally reputed suppliers to source
                consistent PVC raw materials and production inputs.
              </p>
            </article>
            <article class="why-choose__single1 fade-up" data-delay="150">
              <div>
                <img
                  src="assets/images/infrastructure/calendar.jpg"
                  alt="PVC calendering machinery used in Pioneer processing"
                />
              </div>
              <h3>Processing</h3>
              <p>
                Our fully integrated plant supports PVC processing, coating,
                laminating, finishing, and product conversion.
              </p>
            </article>
            <article class="why-choose__single1 fade-up" data-delay="300">
              <div>
                <img
                  src="assets/images/work-process/quality.jpeg"
                  alt="Integrated vinyl production line for controlled quality checks"
                />
              </div>
              <h3>Quality</h3>
              <p>
                Quality is controlled in-house so each batch can meet
                expectations for durability, finish, printability, and use.
              </p>
            </article>
            <article class="why-choose__single1 fade-up" data-delay="450">
              <!-- <span>04</span> -->
              <div>
                <img
                  src="assets/images/work-process/dispatch.jpeg"
                  alt="Finished PVC rolls handled on the production floor before dispatch"
                />
              </div>
              <h3>Dispatch</h3>
              <p>
                Pioneer is building robust domestic and international
                distribution networks for reliable product availability.
              </p>
            </article>
          </div>
        </div>
      </section>


      <!-- ==== ideas inspiration section start ==== -->
      <section class="ideas-inspiration pt-140 pb-140 bg-alt-2" id="gallery">
        <div class="container-lg">
          <div class="row align-items-end gutter-30">
            <div class="col-12 col-lg-7">
              <div class="ideas-inspiration__intro fade-up">
                <p class="txt-light">(Ideas & Inspiration)</p>
                <h2 class="title-animation title-lg-sm elicyon fw-3 mt-12">
                  Explore ideas shaped for modern living
                </h2>
              </div>
            </div>
            <div class="col-12 col-lg-5">
              <p class="ideas-inspiration__text txt-light fade-up">
                Explore Pioneer product applications across signage, decorative
                surfaces, adhesive tapes, and industrial PVC laminated use
                cases.
              </p>
            </div>
          </div>
          <div class="row mt-80">
            <% galleryItems.slice(3).forEach((item) => { %>
              <div class="col-lg-4">
                <%- include('partials/gallery-card', { item, galleryGroup: 'home-gallery' }) %>
              </div>
            <% }); %>
          </div>
          <div class="ideas-inspiration__cta text-center mt-80 fade-up">
            <a class="btn-primary" href="/gallery">
              <span class="btn-animated-text" data-text="View More Ideas"
                >View More Ideas</span
              >
            </a>
          </div>
        </div>
      </section>
      <!-- ==== / ideas inspiration section end ==== -->

      <!-- ==== why choose section start ==== -->
      <section class="why-choose pt-140 pb-140 template-bg">
        <div class="container-lg">
          <div class="row align-items-end gutter-30">
            <div class="col-12 col-lg-7">
              <div class="why-choose__intro fade-up">
                <p class="txt-light">(Why Choose Pioneer)</p>
                <h2 class="title-animation title-lg-sm elicyon fw-3 mt-12">
                  Integrated manufacturing that keeps quality in control
                </h2>
              </div>
            </div>
            <div class="col-12 col-lg-5">
              <p class="why-choose__text txt-light fade-up">
                From raw material sourcing to production, Pioneer combines
                global technology, skilled technicians, and in-house processes
                to deliver consistent PVC products at scale.
              </p>
            </div>
          </div>
          <div class="why-choose__grid mt-80">
            <article class="why-choose__single fade-up">
              <span>01</span>
              <h3>Integrated plant</h3>
              <p>
                Our 6,55,000 sq. ft. facility at SIDCUL Pantnagar supports
                controlled, scalable PVC production.
              </p>
            </article>
            <article class="why-choose__single fade-up" data-delay="150">
              <span>02</span>
              <h3>Wide product range</h3>
              <p>
                Signage media, decorative films, PVC tapes, and industrial
                laminated products are served under one roof.
              </p>
            </article>
            <article class="why-choose__single fade-up" data-delay="300">
              <span>03</span>
              <h3>Quality control</h3>
              <p>
                In-house production and reputed raw-material partners help
                maintain stable quality across every batch.
              </p>
            </article>
            <article class="why-choose__single fade-up" data-delay="450">
              <span>04</span>
              <h3>Domestic and export reach</h3>
              <p>
                Our distribution focus supports both Indian market requirements
                and international business growth.
              </p>
            </article>
          </div>
        </div>
      </section>
      <!-- ==== / why choose section end ==== -->


      
      <!-- ==== home video section start ==== -->
      <section class="home-video pt-100 pb-140 bg-alt-2">
        <div class="container-lg">
          <div class="home-video__frame fade-up mt-60" data-delay="160">
            <video
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              poster="assets/images/wpc-louvers/1.jpeg"
              aria-label="Pioneer decorative louver application video"
            >
              <source src="https://rantechnology.in/pioneer/video.mp4" type="video/mp4" />
            </video>
          </div>
        </div>
      </section>
      <!-- ==== / home video section end ==== -->


      <!-- ==== quote form section start ==== -->
      <section class="quote-maker pt-100 pb-100 template-bg bg-white">
        <div class="container-lg">
          <div class="row">
            <div class="col-12">
              <div class="quote-maker__intro text-center fade-up">
                <p class="txt-light">(Enquire Now)</p>
                <h2 class="title-animation title-lg-sm elicyon fw-3 mt-12">
                 Make an Inquiry
                </h2>
              </div>
              <form
                class="quote-maker__form fade-up mt-80"
                action="#"
                method="post"
              >
                <div class="quote-maker__grid">
                  <div class="quote-maker__field">
                    <input
                      type="text"
                      name="quote-name"
                      id="quoteName"
                      placeholder="Name *"
                      required
                    />
                  </div>
                  <div class="quote-maker__field">
                    <input
                      type="tel"
                      name="quote-mobile"
                      id="quoteMobile"
                      placeholder="Mobile *"
                      required
                    />
                  </div>
                  <div class="quote-maker__field">
                    <input
                      type="email"
                      name="quote-email"
                      id="quoteEmail"
                      placeholder="Email *"
                      required
                    />
                  </div>
                  <div class="quote-maker__field">
                    <input
                      type="text"
                      name="quote-city"
                      id="quoteCity"
                      placeholder="City *"
                      required
                    />
                  </div>
                  <div class="quote-maker__stack">
                    <div class="quote-maker__field">
                      <label for="quoteProduct">Select Product *</label>
                      <select name="quote-product" id="quoteProduct" required>
                        <option value="PVC Decorative Films">
                          PVC Decorative Films
                        </option>
                        <option value="PVC/WPC Interior Louvers">
                          PVC/WPC Interior Louvers
                        </option>
                        <option value="WPC Doors and Frames">
                          WPC Doors and Frames
                        </option>
                        <option value="PVC/WPC Baffles">
                          PVC/WPC Baffles
                        </option>
                      </select>
                    </div>
                    <div class="quote-maker__split">
                      <div class="quote-maker__field">
                        <label for="quoteQuantity"
                          >Approximate Quantity Required *</label
                        >
                        <select
                          name="quote-quantity"
                          id="quoteQuantity"
                          required
                        >
                          <option value="100-500">100-500</option>
                          <option value="500-1000">500-1000</option>
                          <option value="1000+">1000+</option>
                        </select>
                      </div>
                      <div class="quote-maker__field">
                        <label for="quoteUnit">Unit *</label>
                        <select name="quote-unit" id="quoteUnit" required>
                          <option value="">Select</option>
                          <option value="Sq. Ft.">Sq. Ft.</option>
                          <option value="Sq. M.">Sq. M.</option>
                          <option value="Pieces">Pieces</option>
                        </select>
                      </div>
                    </div>
                    <div class="quote-maker__field">
                      <label for="quoteApplication">Application *</label>
                      <select
                        name="quote-application"
                        id="quoteApplication"
                        required
                      >
                        <option value="">Select an option</option>
                        <option value="Signage">Signage</option>
                        <option value="Furniture / Home Decor">
                          Furniture / Home Decor
                        </option>
                        <option value="Industrial">Industrial</option>
                        <option value="Distribution">Distribution</option>
                        <option value="Export">Export</option>
                      </select>
                    </div>
                  </div>
                  <div class="quote-maker__field quote-maker__field--textarea">
                    <textarea
                      name="quote-comments"
                      id="quoteComments"
                      placeholder="Comments"
                    ></textarea>
                  </div>
                </div>
                <div class="quote-maker__cta text-center mt-80">
                  <button
                    type="submit"
                    class="btn-primary"
                    aria-label="Send quote request"
                    title="Send quote request"
                  >
                    <span class="btn-animated-text" data-text="Send">Send</span>
                  </button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </section>
      <!-- ==== / quote form section end ==== -->

      <!-- ==== journal section start ==== -->
      <section class="journal-section pt-140 pb-140 template-bg">
        <div class="container-lg">
          <div class="row">
            <div class="col-12">
              <div class="journal-section__header fade-up">
                <div>
                  <p class="txt-light">(Latest Notes)</p>
                  <h2 class="title-animation title-lg-sm elicyon fw-3 mt-12">
                    Journal
                  </h2>
                </div>
              </div>
              <div class="journal-section__slider swiper mt-60 fade-up">
                <div class="swiper-wrapper">
                  <% blogPosts.forEach((post) => { %>
                    <div class="swiper-slide">
                      <%- include('partials/blog-card', { post }) %>
                    </div>
                  <% }); %>
                </div>
              </div>
              <div class="journal-section__navigation fade-up mt-60">
                <button
                  type="button"
                  class="journal-prev"
                  aria-label="Previous journal"
                  title="Previous journal"
                >
                  <img src="assets/images/left-arrow.webp" alt="Image" />
                </button>
                <button
                  type="button"
                  class="journal-next"
                  aria-label="Next journal"
                  title="Next journal"
                >
                  <img src="assets/images/right-arrow.webp" alt="Image" />
                </button>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ==== footer start ==== -->
      <%- include('partials/footer') %>

      <div class="lines l-alt">
        <div class="line"></div>
        <div class="line"></div>
        <div class="line"></div>
      </div>

      <!-- ==== custom cursor start ==== -->
      <div class="mouseCursor cursor-outer"></div>
      <div class="mouseCursor cursor-inner">
        <span class="drag"> drag </span>
        <span class="view"> view </span>
        <span class="play"> play </span>
      </div>
      <!-- ==== / custom cursor end ==== -->

      <!-- ==== scroll to top start ==== -->
      <button
        class="progress-wrap"
        aria-label="scroll indicator"
        title="back to top"
      >
        <span></span>
        <svg
          class="progress-circle svg-content"
          width="100%"
          height="100%"
          viewBox="-1 -1 102 102"
        >
          <path d="M50,1 a49,49 0 0,1 0,98 a49,49 0 0,1 0,-98" />
        </svg>
      </button>
      <!-- ==== / scroll to top end ==== -->
    </div>
  </body>
</html>
