<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %> | <%= appName %></title>
    <style>
      :root {
        --bg: #f5f6f8;
        --panel: #ffffff;
        --line: #dfe3e8;
        --text: #182230;
        --muted: #667085;
        --accent: #98582f;
        --accent-dark: #6f3a1b;
        --danger: #b42318;
      }

      * {
        box-sizing: border-box;
      }

      body {
        min-height: 100vh;
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: Arial, sans-serif;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button,
      input {
        font: inherit;
      }

      .admin-shell {
        display: grid;
        grid-template-columns: 240px minmax(0, 1fr);
        min-height: 100vh;
      }

      .admin-sidebar {
        display: flex;
        flex-direction: column;
        gap: 18px;
        border-right: 1px solid var(--line);
        background: #111827;
        color: #ffffff;
        padding: 24px 18px;
      }

      .admin-brand {
        font-size: 20px;
        font-weight: 700;
      }

      .admin-nav {
        display: grid;
        gap: 8px;
      }

      .admin-nav a,
      .admin-nav button {
        width: 100%;
        border: 0;
        border-radius: 6px;
        background: transparent;
        color: #e5e7eb;
        cursor: pointer;
        padding: 10px 12px;
        text-align: left;
      }

      .admin-nav a:hover,
      .admin-nav button:hover {
        background: rgba(255, 255, 255, 0.08);
      }

      .admin-main {
        min-width: 0;
      }

      .admin-topbar {
        display: flex;
        min-height: 68px;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid var(--line);
        background: var(--panel);
        padding: 0 28px;
      }

      .admin-content {
        padding: 28px;
      }

      .admin-section {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--panel);
        padding: 22px;
      }

      .admin-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
      }

      .metric {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--panel);
        padding: 18px;
      }

      .metric span,
      .muted {
        color: var(--muted);
      }

      .metric strong {
        display: block;
        margin-top: 8px;
        font-size: 30px;
      }

      .admin-form {
        display: grid;
        gap: 14px;
        max-width: 420px;
      }

      .admin-field {
        display: grid;
        gap: 7px;
      }

      .admin-field label {
        color: var(--muted);
        font-size: 13px;
        font-weight: 700;
      }

      .admin-field input {
        width: 100%;
        border: 1px solid var(--line);
        border-radius: 6px;
        padding: 11px 12px;
      }

      .admin-button {
        border: 0;
        border-radius: 6px;
        background: var(--accent);
        color: #ffffff;
        cursor: pointer;
        padding: 11px 14px;
        font-weight: 700;
      }

      .admin-button:hover {
        background: var(--accent-dark);
      }

      .admin-status {
        min-height: 20px;
        color: var(--muted);
        font-size: 13px;
      }

      .admin-status.is-error {
        color: var(--danger);
      }

      .admin-table-wrap {
        overflow-x: auto;
      }

      .admin-table {
        width: 100%;
        border-collapse: collapse;
      }

      .admin-table th,
      .admin-table td {
        border-bottom: 1px solid var(--line);
        padding: 12px 10px;
        text-align: left;
        vertical-align: top;
      }

      .admin-table th {
        color: var(--muted);
        font-size: 12px;
        text-transform: uppercase;
      }

      .admin-login-page {
        display: grid;
        min-height: 100vh;
        place-items: center;
        padding: 24px;
      }

      @media (max-width: 820px) {
        .admin-shell {
          grid-template-columns: 1fr;
        }

        .admin-sidebar {
          border-right: 0;
        }

        .admin-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
